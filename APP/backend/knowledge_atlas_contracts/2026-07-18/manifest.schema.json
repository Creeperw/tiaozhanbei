{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-atlas-asset-manifest.schema.json",
  "title": "Knowledge Atlas asset import manifest",
  "type": "object",
  "required": ["schema_version", "asset_version", "validated_counts", "components"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "asset_version": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "source_package": { "type": "string", "minLength": 1 },
    "selected_payload": {
      "type": "object",
      "required": ["file_count", "total_bytes"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 1 },
        "total_bytes": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "validated_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name", "source", "root", "target", "file_count", "total_bytes",
          "tree_sha256", "sample_files", "sample_sha256"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "root": { "enum": ["data", "video"] },
          "target": { "type": "string", "pattern": "^[^/\\\\]+$" },
          "file_count": { "type": "integer", "minimum": 1 },
          "total_bytes": { "type": "integer", "minimum": 1 },
          "tree_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "sample_files": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "sample_sha256": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
