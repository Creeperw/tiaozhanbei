# Database: SQLite is the zero-dependency local default.
USE_SQLITE=true
SQLITE_PATH=./health_agent.db
DATABASE_URL=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=health_agent

# LLM: api uses one external endpoint; local uses the two vLLM role endpoints.
LLM_MODE=api
LLM_API_KEY=
LLM_API_BASE_URL=https://api.deepseek.com/anthropic
LLM_API_MODEL=deepseek-v4-flash
PLANNER_EXECUTOR_BASE_URL=http://127.0.0.1:8000/v1
PLANNER_EXECUTOR_MODEL=sining
MANAGER_REVIEWER_BASE_URL=http://127.0.0.1:8001/v1
MANAGER_REVIEWER_MODEL=qwen

# Optional model-backed capabilities.
EMBEDDING_MODE=disabled
EMBEDDING_MODEL_ID=
EMBEDDING_MODEL_PATH=
EMBEDDING_DIMENSIONS=1024
VOICE_MODE=disabled
VISION_API_BASE_URL=
VISION_API_MODEL=qwen3-vl-flash
VISION_API_KEY=
VISION_API_TIMEOUT_SECONDS=30

# Authentication and bootstrap admin. Replace every production value.
SECRET_KEY=development-only-change-me
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sining.local
ADMIN_DEFAULT_PASSWORD=change-me-before-first-run

# Optional email verification.
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_PORT=465
MAIL_SERVER=smtp.qq.com
MAIL_STARTTLS=false
MAIL_SSL_TLS=true

# Optional search and document processing.
EXA_API_KEY=
MARKITDOWN_EXTRACT_TIMEOUT_SECONDS=120
MARKITDOWN_OUTPUT_DIR=./APP/backend/markitdown_output

# Formal question bank and knowledge atlas runtime inputs.
OFFICIAL_EXAM_DATA_DIR=./APP/backend/data/official_exam_2025
KNOWLEDGE_ATLAS_ENABLED=true
KNOWLEDGE_ATLAS_ASSET_VERSION=2026-07-18
KNOWLEDGE_ATLAS_CONTRACT_PATH=./APP/backend/knowledge_atlas_contracts/2026-07-18/manifest.json
KNOWLEDGE_ATLAS_CHAPTER_ROOT=

# Frontend dev server proxy target (set in the shell running Vite).
VITE_API_TARGET=http://127.0.0.1:7860
