# Copy this file to .env.local and fill local secrets there. Never commit secrets.
COMPETITION_APP_MODE=stub
COMPETITION_EXECUTION_ENGINE=langgraph
API_HOST=127.0.0.1
API_PORT=7860
RUNTIME_ROOT=backend/competition_app/runtime
FRONTEND_DIST_ROOT=frontend/llm/dist

# Main model stack. Incoming config_new.py model endpoints are not used.
CHAT_BASE_URL=https://llm-1nvjq1o5rj1bf5yi.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen3.7-max-2026-05-20
DASHSCOPE_API_KEY=
LLM_TIMEOUT_SECONDS=120
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_API_KEY=

# MySQL remains the authoritative persistent store. Empty password uses in-memory
# repositories in stub mode. SQLite fields are reserved for incoming modules.
USE_SQLITE=false
DATABASE_URL=
SQLITE_PATH=competition_app.sqlite3
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=competition_app

AUTH_SESSION_TTL_HOURS=720
# HTTPS deployment: true. Local HTTP development: false.
AUTH_COOKIE_SECURE=false
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sining.local
ADMIN_DEFAULT_PASSWORD=
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Large knowledge assets stay outside Git and may be mounted or linked here.
QUESTION_VECTOR_STORE_ROOT=competition/vdb_store
KNOWLEDGE_VECTOR_STORE_ROOT=competition/vdb_store
KNOWLEDGE_HANDOFF_ROOT=competition/知识星球视频知识库_前端交接包_2026-07-18
KNOWLEDGE_RUNTIME_ROOT=competition/知识星球视频知识库_前端交接包_2026-07-18/知识库管理组件/runtime
KNOWLEDGE_ATLAS_ENABLED=true
KNOWLEDGE_ATLAS_ASSET_VERSION=2026-07-18
KNOWLEDGE_ATLAS_DATA_ROOT=competition/知识星球视频知识库_前端交接包_2026-07-18/知识库管理组件/data/backend_delivery
KNOWLEDGE_ATLAS_VIDEO_ROOT=competition/知识星球视频知识库_前端交接包_2026-07-18/bilibili_video_page/runtime
KNOWLEDGE_ATLAS_CONTRACT_PATH=
KNOWLEDGE_ATLAS_CHAPTER_ROOT=
OFFICIAL_EXAM_DATA_DIR=competition/知识星球视频知识库_前端交接包_2026-07-18/知识库管理组件/data/backend_delivery/08_exam_learning_path_2025

# Existing online search is retained.
EXA_API_KEY=
EXA_NUM_RESULTS=3
EXA_CONTENT_CHAR_LIMIT=500

# Selected incoming file/image/mail capabilities. Voice model loading is disabled
# for the current integration phase and intentionally has no configuration here.
UPLOAD_DIR=uploads
METADATA_FILE=file_metadata.json
MARKITDOWN_OUTPUT_DIR=markitdown_output
MARKITDOWN_EXTRACT_TIMEOUT_SECONDS=120
MAX_TEXT_LENGTH=3000
VISION_API_BASE_URL=
VISION_API_MODEL=qwen3-vl-flash
VISION_API_KEY=
VISION_API_TIMEOUT_SECONDS=30
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_PORT=465
MAIL_SERVER=smtp.qq.com
MAIL_STARTTLS=false
MAIL_SSL_TLS=true

# Temporary compatibility layer; removed after selected modules are migrated.
BACKEND_HANDOFF_ENABLED=true
BACKEND_HANDOFF_ROOT=competition/backend-handoff-20260720
BACKEND_HANDOFF_RUNTIME_ROOT=competition_app/runtime/frontend_backend
BACKEND_HANDOFF_MYSQL_DATABASE=competition_frontend
BACKEND_HANDOFF_SECRET_KEY=
